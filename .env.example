# Properia API — Environment Variables Template
# Copy to .env and fill in real values. NEVER commit .env to git.

# ── App ────────────────────────────────────────────────────────────────────
APP_ENV=dev
PORT=8080
APP_URL=http://localhost:3000

# ── Database ───────────────────────────────────────────────────────────────
POSTGRES_DB=properia
POSTGRES_USER=properia
POSTGRES_PASSWORD=properia_dev_password
POSTGRES_PORT=5432
DATABASE_URL=jdbc:postgresql://localhost:5432/properia?currentSchema=properia

# ── Auth / JWT ─────────────────────────────────────────────────────────────
AUTH_SESSION_SECRET=replace_me_with_a_long_random_secret_at_least_32_chars
AUTH_SESSION_TTL_SECONDS=28800
AUTH_COOKIE_DOMAIN=
AUTH_ALLOWED_ADMIN_EMAILS=admin@properia.pt

# ── Google OAuth ───────────────────────────────────────────────────────────
AUTH_CLIENT_ID=replace_me_google_client_id
AUTH_CLIENT_SECRET=replace_me_google_client_secret

# ── AI ─────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_VISION_MODEL=gpt-4.1-mini
OPENAI_ZONE_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# ── Maps / Routing ─────────────────────────────────────────────────────────
OPENROUTESERVICE_API_KEY=
OVERPASS_API_URL=https://overpass-api.de/api/interpreter

# ── Media / Storage ────────────────────────────────────────────────────────
MEDIA_UPLOAD_PROVIDER=local
MEDIA_LOCAL_UPLOAD_BASE_URL=http://localhost:8080/uploads
CF_R2_ACCOUNT_ID=
CF_R2_ACCESS_KEY_ID=
CF_R2_SECRET_ACCESS_KEY=
CF_R2_BUCKET_MEDIA=
MEDIA_CDN_BASE_URL=

# ── Stripe ─────────────────────────────────────────────────────────────────
BILLING_PROVIDER=fake
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CREDITS_WEBHOOK_SECRET=

# ── Email ──────────────────────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM="Properia <noreply@properia.pt>"

# ── Observability ──────────────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
